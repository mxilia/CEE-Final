SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_BUCKET="karaoke-audio"

# Optional: override public URL base (CDN/custom domain)
# SUPABASE_PUBLIC_URL_PREFIX="https://YOUR_PUBLIC_STORAGE_PREFIX"

# Optional: extra auth header to include when calling callback_url
# Example: Authorization: Bearer <token>
# CALLBACK_AUTH_HEADER="Authorization: Bearer YOUR_CALLBACK_TOKEN"

# Optional: sign callback requests with HMAC-SHA256 so the receiver can verify
# CALLBACK_HMAC_SECRET="your-shared-secret"

